rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() { return request.auth != null; }

    // exists() check prevents null.data error when user doc doesn't exist yet
    function userRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', null)
        : null;
    }
    function isAdmin() { return isAuth() && userRole() == 'admin'; }
    function isSeventy() { return isAuth() && userRole() == 'seventy'; }
    function isPresident() { return isAuth() && userRole() == 'president'; }

    match /users/{uid} {
      allow read: if isAuth() && (request.auth.uid == uid || isAdmin());
      allow create: if isAuth() && request.auth.uid == uid
        && (
          // Presidents self-create via onboarding
          request.resource.data.role == 'president'
          // Admin: email must match settings/admin
          || (request.resource.data.role == 'admin'
              && exists(/databases/$(database)/documents/settings/admin)
              && request.auth.token.email == get(/databases/$(database)/documents/settings/admin).data.get('email', null))
          // Seventy: must have a valid invite
          || (request.resource.data.role == 'seventy'
              && exists(/databases/$(database)/documents/invites/$(request.auth.token.email)))
        );
      allow update: if isAdmin() || (isAuth() && request.auth.uid == uid
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));
    }

    match /invites/{email} {
      allow read: if isAdmin() || (isAuth() && request.auth.token.email == email);
      allow write: if isAdmin();
    }

    match /regions/{regionId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    match /units/{unitId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    match /availability/{seventyUid}/slots/{slotId} {
      allow read: if isAdmin() || isPresident() || (isSeventy() && request.auth.uid == seventyUid);
      allow write: if isAdmin() || (isSeventy() && request.auth.uid == seventyUid);
    }

    match /schedules/{scheduleId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    match /tasks/{taskId} {
      allow read: if isAuth() && (
        isAdmin() || isSeventy() || resource.data.assignedTo == request.auth.uid
      );
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || isSeventy()
        || (isAuth() && resource.data.assignedTo == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'respondedSlots', 'respondedAt']));
    }

    match /notifications/{uid}/items/{notifId} {
      allow read, write: if isAuth() && request.auth.uid == uid;
    }

    match /settings/{doc} {
      // calendar settings (shared calendar IDs) are for admin/seventy only
      allow read: if isAdmin() || isSeventy() || (isAuth() && doc != 'calendar');
      allow write: if isAdmin();
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() { return request.auth != null; }

    // exists() check prevents null.data error when user doc doesn't exist yet
    function userRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', null)
        : null;
    }
    function isAdmin() { return isAuth() && userRole() == 'admin'; }
    function isSeventy() { return isAuth() && userRole() == 'seventy'; }
    function isPresident() { return isAuth() && userRole() == 'president'; }

    match /users/{uid} {
      // Admin: all users. Seventy: all users (needed to resolve president names in task progress).
      // President/others: own document only.
      allow read: if isAuth() && (request.auth.uid == uid || isAdmin() || isSeventy());
      allow create: if isAuth() && request.auth.uid == uid
        && (
          // Presidents self-create via onboarding
          request.resource.data.role == 'president'
          // Admin: email must match settings/admin
          || (request.resource.data.role == 'admin'
              && exists(/databases/$(database)/documents/settings/admin)
              && request.auth.token.email == get(/databases/$(database)/documents/settings/admin).data.get('email', null))
          // Seventy: must have a valid invite
          || (request.resource.data.role == 'seventy'
              && exists(/databases/$(database)/documents/invites/$(request.auth.token.email)))
        );
      // Admin can update any user's doc, but cannot change their own role (self-demotion prevention).
      allow update: if (isAdmin() && (request.auth.uid != uid || !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])))
        || (isAuth() && request.auth.uid == uid && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));
    }

    match /invites/{email} {
      allow read: if isAdmin() || (isAuth() && request.auth.token.email == email);
      allow write: if isAdmin();
    }

    match /regions/{regionId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    match /units/{unitId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    match /availability/{seventyUid}/slots/{slotId} {
      allow read: if isAdmin() || isPresident() || (isSeventy() && request.auth.uid == seventyUid);
      allow write: if isAdmin() || (isSeventy() && request.auth.uid == seventyUid);
    }

    match /schedules/{scheduleId} {
      // Admin: all. Seventy: only schedules they are assigned to (seventyUid).
      // President: only their own confirmed schedules.
      allow read: if isAuth() && (
        isAdmin()
        || (isSeventy() && resource.data.seventyUid == request.auth.uid)
        || resource.data.presidentUid == request.auth.uid
      );
      allow create, update, delete: if isAdmin();
    }

    match /generalSchedules/{scheduleId} {
      // Authenticated users read all (calendar/list). Public page reads isPublic==true only.
      allow read: if isAuth() || resource.data.isPublic == true;
      // Admin and seventy create/manage org-wide events.
      allow create, update, delete: if isAdmin() || isSeventy();
    }

    match /visitPlans/{planId} {
      // 방문 계획 도구는 admin 전용
      allow read, write: if isAdmin();
    }

    match /tasks/{taskId} {
      // Admin: all. Seventy: only tasks in their region (seventyUid matches).
      // President: only tasks assigned to them.
      allow read: if isAuth() && (
        isAdmin()
        || (isSeventy() && resource.data.seventyUid == request.auth.uid)
        || resource.data.assignedTo == request.auth.uid
      );
      allow create, delete: if isAdmin();
      // Admin: unrestricted. Seventy: only their region's tasks, status-only.
      // President: own tasks, limited fields only.
      allow update: if isAdmin()
        || (isSeventy() && resource.data.seventyUid == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['status']))
        || (isAuth() && resource.data.assignedTo == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['status', 'respondedSlots', 'respondedAt',
                            'wardAssignments']));
    }

    match /notifications/{uid}/items/{notifId} {
      allow read, write: if isAuth() && request.auth.uid == uid;
    }

    match /settings/{doc} {
      // All authenticated users can read settings (presidents may need calendar IDs for their own use).
      // Write is admin-only.
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    match /userSettings/{uid} {
      allow read, write: if isAuth() && request.auth.uid == uid;
    }
  }
}
